<Page
    x:Class="WebAppBuilder.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource LayerFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Page.Resources>

    <Grid>
        <ScrollViewer>
            <StackPanel Padding="40" Spacing="24" MaxWidth="850" HorizontalAlignment="Center">
                <TextBlock Text="Web App Builder" Style="{StaticResource TitleTextBlockStyle}" HorizontalAlignment="Left"/>
                <TextBlock Text="Create a standalone desktop application from any website." Style="{StaticResource BodyTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Margin="0,-12,0,0"/>

                <!-- Identity -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Basic Configuration" Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <TextBox x:Name="AppNameBox" Header="App Name" PlaceholderText="e.g. GitHub"/>
                        <TextBox x:Name="AppUrlBox" Header="Website URL" PlaceholderText="https://..."/>
                        
                        <StackPanel Spacing="8">
                            <TextBlock Text="App Icon" Style="{StaticResource BodyTextBlockStyle}"/>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="IconPathBox" PlaceholderText="Auto-favicon if empty" IsReadOnly="True"/>
                                <Button Grid.Column="1" Content="Browse Icon..." Click="BrowseIcon_Click"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Visuals -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Splash Screen Customization" Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <Grid ColumnSpacing="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Spacing="12">
                                <ComboBox x:Name="SplashTemplateCombo" Header="Animation Template" HorizontalAlignment="Stretch" SelectedIndex="0">
                                    <ComboBoxItem Content="Modern Minimal" Tag="modern"/>
                                    <ComboBoxItem Content="Glassmorphism" Tag="glass"/>
                                    <ComboBoxItem Content="Gradient Wave" Tag="gradient"/>
                                    <ComboBoxItem Content="Elegant Reveal" Tag="reveal"/>
                                </ComboBox>
                                
                                <TextBlock Text="Splash Background" Style="{StaticResource BodyTextBlockStyle}"/>
                                <ColorPicker x:Name="SplashColorPicker" Color="White" IsAlphaEnabled="False" IsMoreButtonVisible="False"/>
                            </StackPanel>

                            <StackPanel Spacing="12" Grid.Column="1">
                                <TextBlock Text="Text &amp; Loader Color" Style="{StaticResource BodyTextBlockStyle}" Margin="0,0,0,0"/>
                                <ColorPicker x:Name="TextColorPicker" Color="#333333" IsAlphaEnabled="False" IsMoreButtonVisible="False"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Advanced -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Advanced Features" Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <CheckBox x:Name="BlockAdsCheck" Content="Enable Ad-Blocking (Experimental)"/>
                        <CheckBox x:Name="ForceDarkCheck" Content="Enable Force Dark Mode (Experimental)"/>
                        <TextBox x:Name="CustomCssBox" Header="Custom CSS Injection" PlaceholderText="/* CSS */" AcceptsReturn="True" Height="100" FontFamily="Consolas"/>
                    </StackPanel>
                </Border>

                <!-- Build -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Build &amp; Package" Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <ComboBox x:Name="FormatComboBox" Header="Output Format" HorizontalAlignment="Stretch" SelectedIndex="0">
                            <ComboBoxItem Content="Windows Installer (NSIS)" Tag="win-nsis"/>
                            <ComboBoxItem Content="Windows Portable (.exe)" Tag="win-portable"/>
                            <ComboBoxItem Content="Both (Installer &amp; Portable)" Tag="win-both"/>
                        </ComboBox>
                        
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="PreviewButton" Content="Preview App" Click="PreviewButton_Click" HorizontalAlignment="Stretch" Height="40"/>
                            <Button x:Name="BuildButton" Content="Build App" Click="BuildButton_Click" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" Height="40" Grid.Column="1"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Status Area -->
                <StackPanel Spacing="12">
                    <TextBlock x:Name="BuildStatusText" Text="Build Status: Ready" Style="{StaticResource CaptionTextBlockStyle}"/>
                    <ProgressBar x:Name="BuildProgressBar" Value="0" Maximum="100" Height="10"/>
                    <InfoBar x:Name="StatusInfoBar" IsOpen="False" IsClosable="True" />
                </StackPanel>

                <!-- Logs -->
                <Border Style="{StaticResource CardStyle}" Height="250">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Build Logs" Margin="0,0,0,8" FontWeight="Bold"/>
                        <ScrollViewer x:Name="LogScrollViewer" Grid.Row="1">
                            <TextBox x:Name="LogTextBox" IsReadOnly="True" AcceptsReturn="True" Background="Transparent" BorderThickness="0" FontSize="11" FontFamily="Consolas"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
