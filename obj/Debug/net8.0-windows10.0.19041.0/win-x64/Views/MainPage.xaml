<Page
    x:Class="WebAppBuilder.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource LayerFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Page.Resources>

    <NavigationView x:ConnectionId='2' x:Name="RootNav" PaneDisplayMode="Left" IsSettingsVisible="False" IsBackButtonVisible="Collapsed">
        <NavigationView.MenuItems>
            <NavigationViewItem Content="Create New" Icon="Add" Tag="create"/>
            <NavigationViewItem Content="Update Existing" Icon="Refresh" Tag="update"/>
        </NavigationView.MenuItems>

        <Grid Padding="40">
            <ScrollViewer>
                <StackPanel Spacing="24" MaxWidth="900" HorizontalAlignment="Stretch">
                    
                    <!-- Create Section -->
                    <StackPanel x:ConnectionId='3' x:Name="CreateSection" Spacing="24">
                        <TextBlock Text="Build a New Web App" Style="{StaticResource TitleTextBlockStyle}"/>
                        
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Identity &amp; Source" Style="{StaticResource SubtitleTextBlockStyle}"/>
                                <TextBox x:ConnectionId='19' x:Name="AppNameBox" Header="App Name" PlaceholderText="e.g. GitHub"/>
                                <TextBox x:ConnectionId='20' x:Name="AppUrlBox" Header="Website URL" PlaceholderText="https://..."/>
                                
                                <StackPanel Spacing="8">
                                    <TextBlock Text="App Icon" Style="{StaticResource BodyTextBlockStyle}"/>
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:ConnectionId='21' x:Name="IconPathBox" PlaceholderText="Auto-favicon if empty" IsReadOnly="True"/>
                                        <Button x:ConnectionId='22' Grid.Column="1" Content="Browse..."                         />
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Visual Customization" Style="{StaticResource SubtitleTextBlockStyle}"/>
                                <Grid ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Spacing="12">
                                        <ComboBox x:ConnectionId='16' x:Name="SplashTemplateCombo" Header="Animation Template" HorizontalAlignment="Stretch" SelectedIndex="0">
                                            <ComboBoxItem Content="Modern Minimal" Tag="modern"/>
                                            <ComboBoxItem Content="Glassmorphism" Tag="glass"/>
                                            <ComboBoxItem Content="Gradient Wave" Tag="gradient"/>
                                            <ComboBoxItem Content="Elegant Reveal" Tag="reveal"/>
                                        </ComboBox>
                                        
                                        <TextBlock Text="Splash Background" Style="{StaticResource BodyTextBlockStyle}"/>
                                        <ColorPicker x:ConnectionId='17' x:Name="SplashColorPicker" Color="White" IsAlphaEnabled="False" IsMoreButtonVisible="False"/>
                                        
                                        <TextBlock Text="Text &amp; Loader Color" Style="{StaticResource BodyTextBlockStyle}"/>
                                        <ColorPicker x:ConnectionId='18' x:Name="TextColorPicker" Color="#333333" IsAlphaEnabled="False" IsMoreButtonVisible="False"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Packaging Options" Style="{StaticResource SubtitleTextBlockStyle}"/>
                                <ComboBox x:ConnectionId='13' x:Name="FormatComboBox" Header="Output Format" HorizontalAlignment="Stretch" SelectedIndex="0">
                                    <ComboBoxItem Content="Windows Installer (NSIS)" Tag="win-nsis"/>
                                    <ComboBoxItem Content="Windows Portable (.exe)" Tag="win-portable"/>
                                    <ComboBoxItem Content="Both (Installer &amp; Portable)" Tag="win-both"/>
                                </ComboBox>
                                
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:ConnectionId='14' x:Name="PreviewButton" Content="Preview App (Instant)"                             HorizontalAlignment="Stretch" Height="40"/>
                                    <Button x:ConnectionId='15' x:Name="BuildButton" Content="Full Package &amp; Build"                           Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" Height="40" Grid.Column="1"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Update Section (Hidden by default) -->
                    <StackPanel x:ConnectionId='4' x:Name="UpdateSection" Spacing="24" Visibility="Collapsed">
                        <TextBlock Text="Update an Existing App" Style="{StaticResource TitleTextBlockStyle}"/>
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel Spacing="16">
                                <TextBlock Text="Select the folder of a previously built app to update its core logic and settings to the latest version." 
                                           Style="{StaticResource BodyTextBlockStyle}" TextWrapping="Wrap"/>
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:ConnectionId='11' x:Name="UpdateAppPathBox" PlaceholderText="C:\Users\...\Completed Apps\My App" IsReadOnly="True"/>
                                    <Button x:ConnectionId='12' Grid.Column="1" Content="Select Folder"                               />
                                </Grid>
                                <Button x:ConnectionId='10' x:Name="UpdateAppButton" Content="Update App Files"                               Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Shared Status Area -->
                    <StackPanel Spacing="12">
                        <TextBlock x:ConnectionId='7' x:Name="BuildStatusText" Text="Build Status: Ready" Style="{StaticResource CaptionTextBlockStyle}"/>
                        <ProgressBar x:ConnectionId='8' x:Name="BuildProgressBar" Value="0" Maximum="100" Height="10"/>
                        <InfoBar x:ConnectionId='9' x:Name="StatusInfoBar" IsOpen="False" IsClosable="True" />
                    </StackPanel>

                    <!-- Logs -->
                    <Border Style="{StaticResource CardStyle}" Height="300">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Build Logs" Margin="0,0,0,8" FontWeight="Bold"/>
                            <ScrollViewer x:ConnectionId='5' x:Name="LogScrollViewer" Grid.Row="1">
                                <TextBox x:ConnectionId='6' x:Name="LogTextBox" IsReadOnly="True" AcceptsReturn="True" Background="Transparent" BorderThickness="0" FontSize="11" FontFamily="Consolas"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </NavigationView>
</Page>

